# Cloudflare Turnstile — server verifies tokens from the SPA on AI routes (explore, expand, explain, …).
# Get keys at https://dash.cloudflare.com/ → Turnstile. Use dummy keys for automated tests if needed.
TURNSTILE_SECRET_KEY=
# Emergency bypass (not for production unless you accept open AI endpoints):
# DISABLE_TURNSTILE=1

DEEPSEEK_API_KEY=your_deepseek_api_key_here
# Optional: override V4 model ids (defaults: deepseek-v4-flash, deepseek-v4-pro)
# DEEPSEEK_V4_FLASH_MODEL=deepseek-v4-flash
# DEEPSEEK_V4_PRO_MODEL=deepseek-v4-pro
# V4 thinking mode on chat.completions (reasoning_effort + extra_body). Set to 0 to disable.
# DEEPSEEK_THINKING_ENABLED=1
GEMINI_API_KEY=your_gemini_api_key_here
GCLOUD_PROJECT=your-gcp-project-id
# Optional: only if you use a named Firestore database. Leave unset for the default database.
# FIRESTORE_DATABASE_ID=my-named-db
PORT=4000
# Production: shared /api rate limits use Firestore (api_rate_limits). Set to 0 to use in-memory store only.
# USE_FIRESTORE_RATE_LIMIT=0
# Development: set to 1 to test the Firestore store (requires valid GCP credentials).
# USE_FIRESTORE_RATE_LIMIT=1
# LLM usage counter → Firestore app_metrics/llm_calls (batched). Set to 0/false/off to disable.
LLM_METRICS_ENABLED=1
# Flush interval in ms (min 5000). Optional; default 60000.
# LLM_METRICS_FLUSH_MS=60000
