DEEPSEEK_API_KEY=your_deepseek_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
GCLOUD_PROJECT=your-gcp-project-id
FIRESTORE_DATABASE_ID=your-database-name
PORT=4000
# LLM usage counter → Firestore app_metrics/llm_calls (batched). Set to 0/false/off to disable.
LLM_METRICS_ENABLED=1
# Flush interval in ms (min 5000). Optional; default 60000.
# LLM_METRICS_FLUSH_MS=60000
